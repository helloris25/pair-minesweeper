{
  "name": "pair-minesweeper-client",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . && npm run lint:styles",
    "lint:fix": "eslint . --fix",
    "lint:styles": "stylelint \"src/**/*.{vue,css}\"",
    "lint:styles:fix": "stylelint \"src/**/*.{vue,css}\" --fix",
    "format": "prettier --write \"src/**/*.{ts,vue}\" \"*.{js,ts,json}\""
  },
  "dependencies": {
    "socket.io-client": "^4.7.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@vitejs/plugin-vue": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.1",
    "stylelint": "^16.26.1",
    "stylelint-config-recess-order": "^7.6.1",
    "stylelint-config-standard-vue": "^1.0.0",
    "stylelint-order": "^8.0.0",
    "typescript": "~5.6.0",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.0.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.1.0"
  }
}
